# Async behavior
SIMULATE_STAGE_DELAY_SECONDS=0.6
SIMULATE_JOB_FAILURE_PROBABILITY=0.0

# Data storage
DATASET_STORAGE_ROOT=data/raw

# Kaggle ingestion
ENABLE_REAL_KAGGLE_INGESTION=false
KAGGLE_API_TOKEN=
# Legacy fallback:
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# OpenAI
ENABLE_REAL_AI_INTERPRETATION=true
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
ENABLE_CLEANING_OUTPUT=false
